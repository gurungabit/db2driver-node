{
  "name": "@gurungabit/db2-node",
  "version": "0.1.7-zos.21",
  "description": "Zero-dependency DB2 driver for Node.js, built with pure Rust",
  "main": "index.cjs",
  "types": "types.d.ts",
  "exports": {
    ".": {
      "types": "./types.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.cjs"
    }
  },
  "files": [
    "README.md",
    "index.cjs",
    "index.js",
    "index.mjs",
    "index.d.ts",
    "types.d.ts",
    "db2-node.*.node"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "node ./scripts/verify-prepublish.cjs",
    "test": "node --test"
  },
  "napi": {
    "name": "db2-node",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-musl",
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "keywords": [
    "db2",
    "database",
    "drda",
    "driver",
    "napi",
    "rust"
  ],
  "homepage": "https://github.com/gurungabit/db2-node",
  "bugs": {
    "url": "https://github.com/gurungabit/db2-node/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gurungabit/db2-node.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^2"
  }
}
